# Dependencies & build output — reinstalled/rebuilt inside the image.
node_modules
dist
dist-web
coverage
.vitest
*.tsbuildinfo

# Version control & local agent state.
.git
.gitignore
.claude

# Task briefs / planning docs — not needed at runtime, keep image context small.
tasks
PLAN.md
ORCHESTRATION.md
DESIGN.md

# Env & local secrets — provider auth is mounted at runtime, never copied in.
.env
.env*.local
*.pem

# Deploy/CI scaffolding (Track B) — not part of the app image build context.
deploy
.github
docs

# Editor/OS cruft.
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker/compose files themselves don't need to be in the build context.
Dockerfile
docker-compose.yml
.dockerignore
