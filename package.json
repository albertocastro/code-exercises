{
  "name": "code-exercises",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/runtime.mjs install all",
    "runtime:install": "node scripts/runtime.mjs install all",
    "runtime:up": "node scripts/runtime.mjs up all",
    "start": "tsx cli.ts",
    "serve": "node server/index.mjs",
    "start:server": "node server/index.mjs",
    "test": "jest",
    "watch": "jest --watchAll",
    "test:react": "vitest run",
    "watch:react": "vitest",
    "test:all": "jest && vitest run",
    "preview:web": "vite",
    "web": "node scripts/runtime.mjs up all && vite --config vite.web.config.ts",
    "web:build": "vite build --config vite.web.config.ts"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jest": "^29.7.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "ts-jest": "^29.2.3",
    "typescript": "^5.4.5",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "<rootDir>/jest.environment.ts",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/cli.ts"
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@shikijs/monaco": "^1.29.2",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "html2canvas": "^1.4.1",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^2.1.9",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.29.2",
    "sucrase": "^3.35.1",
    "tsx": "^4.22.4"
  }
}
