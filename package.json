{
  "name": "code-exercises",
  "private": true,
  "scripts": {
    "start": "tsx cli.ts",
    "test": "jest",
    "watch": "jest --watchAll"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "<rootDir>/jest.environment.ts",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": ["/node_modules/", "/cli.ts"]
  }
}
